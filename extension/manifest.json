{
  "manifest_version": 3,
  "name": "PitchIQ Live Overlay",
  "version": "1.0.0",
  "description": "Real-time MLB pitcher analytics overlay for MLB.TV",
  "permissions": ["storage", "alarms"],
  "host_permissions": [
    "https://www.mlb.com/*",
    "https://mlb.com/*",
    "http://localhost:8002/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://www.mlb.com/*", "https://mlb.com/*"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16":  "icons/icon16.png",
      "48":  "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  }
}
